#!/usr/bin/env bash
set -euo pipefail

mkdir -p "$HOME/.local/bin"

log_step() {
  printf '==> %s\n' "$1"
}

install_oh_my_zsh() {
  if [ -d "$HOME/.oh-my-zsh" ]; then
    return
  fi

  tmp="$(mktemp)"
  curl -fsSL https://raw.githubusercontent.com/ohmyzsh/ohmyzsh/master/tools/install.sh -o "$tmp"
  RUNZSH=no CHSH=no KEEP_ZSHRC=yes sh "$tmp"
  rm -f "$tmp"
}

install_zsh_plugin() {
  local name="$1"
  local repo="$2"
  local dest="${ZSH_CUSTOM:-$HOME/.oh-my-zsh/custom}/plugins/$name"

  if [ -d "$dest" ]; then
    return
  fi

  git clone --depth=1 "$repo" "$dest"
}

install_starship() {
  if command -v starship >/dev/null 2>&1; then
    return
  fi

  tmp="$(mktemp)"
  curl -fsSL https://starship.rs/install.sh -o "$tmp"
  sh "$tmp" -y
  rm -f "$tmp"
}

install_rustup() {
  if command -v rustup >/dev/null 2>&1; then
    return
  fi

  tmp="$(mktemp)"
  curl -fsSL https://sh.rustup.rs -o "$tmp"
  sh "$tmp" -y --no-modify-path
  rm -f "$tmp"
}

load_cargo_env() {
  if [ -s "$HOME/.cargo/env" ]; then
    # shellcheck disable=SC1091
    . "$HOME/.cargo/env"
  fi
}

install_tree_sitter() {
  load_cargo_env

  if command -v tree-sitter >/dev/null 2>&1 && tree-sitter --help 2>/dev/null | grep -q 'build'; then
    return
  fi

  cargo install tree-sitter-cli
}

install_n() {
  if [ "$(uname -s)" = "Darwin" ]; then
    if ! command -v brew >/dev/null 2>&1; then
      echo "Homebrew is required to install n on macOS. Install it from https://brew.sh, then rerun this command." >&2
      exit 1
    fi

    brew list n >/dev/null 2>&1 || brew install n
    return
  fi

  local owner
  owner="$(id -un)"

  if ! command -v n >/dev/null 2>&1; then
    tmp="$(mktemp)"
    curl -fsSL https://raw.githubusercontent.com/tj/n/master/bin/n -o "$tmp"
    sudo bash "$tmp" install lts
    rm -f "$tmp"
  fi

  # On Ubuntu, n installs into /usr/local and may leave the cache and Node.js
  # destination directories owned by root. Ensure future n/node/npm updates can
  # run without sudo.
  sudo mkdir -p /usr/local/n
  sudo chown -R "$owner" /usr/local/n

  sudo mkdir -p /usr/local/bin /usr/local/lib /usr/local/include /usr/local/share
  sudo chown -R "$owner" /usr/local/bin /usr/local/lib /usr/local/include /usr/local/share

  n lts
}

install_atuin() {
  if command -v atuin >/dev/null 2>&1; then
    return
  fi

  tmp="$(mktemp)"
  curl -fsSL https://setup.atuin.sh -o "$tmp"
  sh "$tmp"
  rm -f "$tmp"
}

install_bob() {
  export PATH="$HOME/.local/share/bob/nvim-bin:$HOME/.local/bin:$PATH"

  if ! command -v bob >/dev/null 2>&1; then
    tmp="$(mktemp)"
    curl -fsSL https://raw.githubusercontent.com/MordechaiHadad/bob/master/scripts/install.sh -o "$tmp"
    bash "$tmp"
    rm -f "$tmp"
  fi

  if ! command -v nvim >/dev/null 2>&1; then
    bob use stable
  fi
}

install_tailscale() {
  if command -v tailscale >/dev/null 2>&1; then
    return
  fi

  tmp="$(mktemp)"
  curl -fsSL https://tailscale.com/install.sh -o "$tmp"
  sh "$tmp"
  rm -f "$tmp"
}

install_herdr() {
  if command -v herdr >/dev/null 2>&1; then
    return
  fi

  curl -fsSL https://herdr.dev/install.sh | sh
}

log_step "oh-my-zsh"
install_oh_my_zsh
log_step "zsh-syntax-highlighting"
install_zsh_plugin zsh-syntax-highlighting https://github.com/zsh-users/zsh-syntax-highlighting.git
log_step "zsh-autosuggestions"
install_zsh_plugin zsh-autosuggestions https://github.com/zsh-users/zsh-autosuggestions.git
log_step "starship"
install_starship
log_step "rustup"
install_rustup
log_step "tree-sitter-cli"
install_tree_sitter
log_step "n and Node.js LTS"
install_n
log_step "atuin"
install_atuin
log_step "bob and Neovim"
install_bob
log_step "tailscale"
install_tailscale
log_step "herdr"
install_herdr
